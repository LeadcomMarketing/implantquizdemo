# Meta / lead forwarding
META_PIXEL_ID=
META_CAPI_TOKEN=
NEXT_PUBLIC_META_PIXEL_ID=
LEAD_WEBHOOK_URL=

# Admin panel (/admin) — set a strong password
ADMIN_PASSWORD=
# Optional: dedicated secret for signing the admin session cookie.
# If unset, ADMIN_PASSWORD is used. Changing it logs everyone out.
ADMIN_SECRET=

# Vercel Blob — clinic storage. Auto-added when you link a Blob store in Vercel.
# For local dev, run `vercel env pull` or paste the token here.
BLOB_READ_WRITE_TOKEN=
